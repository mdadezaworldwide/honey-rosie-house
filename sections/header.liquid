<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand">
      {%- if section.settings.logo != blank -%}
        <img
          class="site-header__logo-img"
          src="{{ section.settings.logo | image_url: height: 64 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo.width }}"
          height="32"
          loading="eager"
        >
      {%- elsif images['logo.jpg'] -%}
        <img
          class="site-header__logo-img"
          src="{{ 'logo.jpg' | asset_url }}"
          alt="{{ shop.name }}"
          height="32"
          loading="eager"
        >
      {%- endif -%}
      <span class="site-header__brand-name">{{ shop.name }}</span>
    </a>
    <nav class="site-header__nav">
      <a href="/collections/all">ITEMS</a>
      <a href="/cart">
        CART
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
