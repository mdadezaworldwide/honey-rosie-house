<div style="max-width:var(--max-w);margin:0 auto;padding:28px 20px;">
  <h1 style="font-family:'Playfair Display',serif;font-size:18px;font-weight:700;margin-bottom:20px;">CART</h1>

  {%- if cart.item_count > 0 -%}
    <form action="/cart" method="post">
      {%- for item in cart.items -%}
        <div style="display:flex;gap:14px;align-items:flex-start;padding:14px 0;border-bottom:1px solid var(--border);">
          <div style="width:80px;height:100px;border-radius:6px;overflow:hidden;flex-shrink:0;background:var(--card-bg);">
            {%- if item.image -%}
              <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" style="width:100%;height:100%;object-fit:cover;">
            {%- endif -%}
          </div>
          <div style="flex:1;">
            <div style="font-size:13px;font-weight:500;margin-bottom:4px;">{{ item.product.title }}</div>
            {%- unless item.variant.title == 'Default Title' -%}
              <div style="font-size:10px;color:var(--text-light);margin-bottom:4px;">{{ item.variant.title }}</div>
            {%- endunless -%}
            <div style="font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;">
              {{ item.final_line_price | money_without_trailing_zeros }}
              <span style="font-size:9px;color:var(--text-light);font-weight:400;">税込</span>
            </div>
            <div style="font-size:10px;color:var(--text-light);margin-top:2px;">x{{ item.quantity }}</div>
          </div>
          <a href="/cart/change?id={{ item.key }}&quantity=0" style="font-size:10px;color:var(--text-light);opacity:.5;">削除</a>
        </div>
      {%- endfor -%}

      <div style="padding:20px 0;text-align:right;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;margin-bottom:4px;">
          {{ cart.total_price | money_without_trailing_zeros }}
          <span style="font-size:10px;color:var(--text-light);font-weight:400;">税込</span>
        </div>
        <button type="submit" name="checkout" class="pd-add-btn" style="max-width:320px;margin-left:auto;">
          CHECKOUT
        </button>
      </div>
    </form>
  {%- else -%}
    <p style="font-size:13px;color:var(--text-light);padding:40px 0;text-align:center;">
      カートにアイテムがありません
    </p>
    <div style="text-align:center;">
      <a href="/" style="font-family:'Cormorant Garamond',serif;font-size:12px;font-weight:600;letter-spacing:.15em;color:var(--text-mid);">BACK TO TOP &rarr;</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart",
  "tag": "section"
}
{% endschema %}
