{%- if section.settings.show -%}
<div class="collection-info">
  <div>
    <div class="collection-info__title">{{ section.settings.title | default: 'Spring 2026 Collection' }}</div>
    <div class="collection-info__date">{{ section.settings.date | default: '2026.04.01 — 04.14' }}</div>
  </div>
  <div class="collection-info__badge">{{ section.settings.badge_text | default: 'NOW OPEN' }}</div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Collection Info",
  "settings": [
    {
      "type": "checkbox",
      "id": "show",
      "label": "Show collection info (toggle for drop period)",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Collection title",
      "default": "Spring 2026 Collection"
    },
    {
      "type": "text",
      "id": "date",
      "label": "Date range",
      "default": "2026.04.01 — 04.14"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "NOW OPEN"
    }
  ],
  "presets": [
    {
      "name": "Collection Info"
    }
  ]
}
{% endschema %}
