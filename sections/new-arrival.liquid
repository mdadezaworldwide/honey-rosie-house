<div class="sec-head">
  <div>
    <span class="sec-head__title">NEW ARRIVAL</span>
    <span class="sec-head__sub">新着アイテム</span>
  </div>
  {%- if section.settings.collection -%}
    <a href="{{ section.settings.collection.url }}" class="sec-head__viewall">VIEW ALL &rarr;</a>
  {%- endif -%}
</div>

<div class="product-scroll">
  <div class="product-row">
    {%- if section.settings.collection -%}
      {%- for product in section.settings.collection.products limit: section.settings.limit -%}
        {%- assign badge_type = '' -%}
        {%- for tag in product.tags -%}
          {%- if tag == 'new' -%}{%- assign badge_type = 'new' -%}
          {%- elsif tag == 'limited' -%}{%- assign badge_type = 'limited' -%}
          {%- endif -%}
        {%- endfor -%}
        {% render 'product-card', product: product, badge: badge_type %}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Placeholder cards for preview {%- endcomment -%}
      {%- for i in (1..6) -%}
        <div class="p-card">
          <div class="p-card__img">
            <div style="width:100%;height:100%;background:linear-gradient(155deg,#ecdad4 0%,#e0ccc4 50%,#d8c0ba 100%);"></div>
            {%- if i == 1 or i == 2 -%}
              <span class="p-card__badge p-card__badge--new">NEW</span>
            {%- elsif i == 3 -%}
              <span class="p-card__badge p-card__badge--limited">LIMITED</span>
            {%- endif -%}
          </div>
          <div class="p-card__body">
            <div class="p-card__name">Sample Product {{ i }}</div>
            <div class="p-card__variant">3 colors / 4 sizes</div>
            <div class="p-card__price">&yen;4,800 <span class="p-card__tax">税込</span></div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "New Arrival",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Max products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "New Arrival"
    }
  ]
}
{% endschema %}
