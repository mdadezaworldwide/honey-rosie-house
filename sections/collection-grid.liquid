<div class="sec-head">
  <div>
    <span class="sec-head__title">{{ collection.title }}</span>
    <span class="sec-head__sub">{{ collection.products_count }} items</span>
  </div>
</div>

<div class="product-grid">
  {%- for product in collection.products -%}
    {%- assign badge_type = '' -%}
    {%- for tag in product.tags -%}
      {%- if tag == 'new' -%}{%- assign badge_type = 'new' -%}
      {%- elsif tag == 'limited' -%}{%- assign badge_type = 'limited' -%}
      {%- endif -%}
    {%- endfor -%}
    {% render 'product-card', product: product, badge: badge_type %}
  {%- endfor -%}
</div>

{%- if collection.products.size == 0 -%}
  <div style="max-width:var(--max-w);margin:0 auto;padding:40px 20px;text-align:center;">
    <p style="font-size:13px;color:var(--text-light);">現在販売中のアイテムはありません</p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section"
}
{% endschema %}
